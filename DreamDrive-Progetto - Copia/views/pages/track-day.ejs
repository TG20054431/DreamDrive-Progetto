<!doctype html>
<html lang="it">
<head>
    <title>DreamDrive | Track Day</title>
    <%- include('../partials/head') %>
</head>
<body>
    <%- include('../partials/nav') %>

    <div class="container mt-5">
        <h1 class="text-center mb-4">Track Day</h1>
        <p class="text-center lead">La nostra selezione di auto disponibili per i track day.</p>
        <p class="text-center text-success fw-bold mb-4">Il prezzo per ogni auto è di €350 per sessione track-day<br>E' necessario aver compiuto almeno 18 anni.</p>

        <!-- Filter Section -->
        <div class="filters mb-4">
            <div class="row g-3">
                <!-- Nationality Filter -->
                <div class="col-md-4">
                    <select class="form-select" id="nationalityFilter">
                        <option value="all">Tutte le Nazionalità</option>
                        <option value="german">Germania</option>
                        <option value="italian">Italia</option>
                        <option value="british">Inghilterra</option>
                        <option value="france">Francia</option>
                        <option value="japan">Giappone</option>
                    </select>
                </div>
                <!-- Brand Filter -->
                <div class="col-md-4">
                    <select class="form-select" id="brandFilter">
                        <option value="all">Tutti i Brand</option>
                        <option value="audi">Audi</option>
                        <option value="pagani">Pagani</option>
                        <option value="mclaren">McLaren</option>
                        <option value="lamborghini">Lamborghini</option>
                        <option value="bugatti">Bugatti</option>
                        <option value="nissan">Nissan</option>
                    </select>
                </div>
                <!-- Engine Filter -->
                <div class="col-md-4">
                    <select class="form-select" id="engineFilter">
                        <option value="all">Tutti i Motori</option>
                        <option value="elettrico">Elettrico</option>
                        <option value="v6">V6</option>
                        <option value="v8">V8</option>
                        <option value="v10">V10</option>
                        <option value="v12">V12</option>
                        <option value="w16">W16</option>
                    </select>
                </div>
                <div class="col-12 text-center mt-3">
                    <button id="searchButton" class="btn btn-teal px-4">Cerca</button>
                </div>
            </div>
        </div>
    
        <div class="row row-cols-1 row-cols-md-2 g-4 justify-content-center" id="car-grid">
            <div class="col" data-nationality="german" data-brand="audi" data-engine="elettrico">
                <div class="card h-100">
                    <img src="/images/track-day-auto/td1.jpg" class="card-img-top card-img-fixed" alt="Audi e-tron GT">
                    <div class="card-body">
                        <h5 class="card-title">AUDI e-tron GT</h5>
                        <p class="card-text">Doppio motore elettrico da 680 Kw, 925 CV, 0-100 km/h in 2.5 secondi.</p>
                        <a href="/prenota?service=track-day&car=audi-etron" class="btn btn-teal">PRENOTA</a>
                    </div>
                </div>
            </div>

            <div class="col" data-nationality="italian" data-brand="pagani" data-engine="v12">
                <div class="card h-100">
                    <img src="/images/track-day-auto/td2.jpg" class="card-img-top card-img-fixed" alt="Pagani Zonda R">
                    <div class="card-body">
                        <h5 class="card-title">PAGANI ZONDA R</h5>
                        <p class="card-text">Motore V12 AMG, 6.0 litri, 750 CV, 0-100 km/h in 2.7 secondi.</p>
                        <a href="/prenota?service=track-day&car=pagani-zonda" class="btn btn-teal">PRENOTA</a>
                    </div>
                </div>
            </div>

            <div class="col" data-nationality="british" data-brand="mclaren" data-engine="v8">
                <div class="card h-100">
                    <img src="/images/track-day-auto/td3.jpg" class="card-img-top card-img-fixed" alt="McLaren Senna GTR">
                    <div class="card-body">
                        <h5 class="card-title">McLAREN SENNA GTR</h5>
                        <p class="card-text">Motore V8 Biturbo, 4.0 litri, 814 CV, 0-100 km/h in 2.8 secondi.</p>
                        <a href="/prenota?service=track-day&car=mclaren-senna" class="btn btn-teal">PRENOTA</a>
                    </div>
                </div>
            </div>

            <div class="col" data-nationality="italian" data-brand="lamborghini" data-engine="v10">
                <div class="card h-100">
                    <img src="/images/track-day-auto/td4.jpg" class="card-img-top card-img-fixed" alt="Lamborghini Huracán GT3 EVO 2">
                    <div class="card-body">
                        <h5 class="card-title">LAMBORGHINI HURACÁN GT3 EVO 2</h5>
                        <p class="card-text">Motore V10, 5.2 litri, 620 CV, 0-100 km/h in 3.2 secondi.</p>
                        <a href="/prenota?service=track-day&car=lamborghini-huracan" class="btn btn-teal">PRENOTA</a>
                    </div>            
                </div>
            </div>

            <div class="col" data-nationality="france" data-brand="bugatti" data-engine="w16">
                <div class="card h-100">
                    <img src="/images/track-day-auto/td5.jpg" class="card-img-top card-img-fixed" alt="Bugatti Chiron">
                    <div class="card-body">
                        <h5 class="card-title">BUGATTI CHIRON</h5>
                        <p class="card-text">Motore W16 Quadriturbo, 8.0 litri, 1500 CV, 0-100 km/h in 2.3 secondi.</p>
                        <a href="/prenota?service=track-day&car=bugatti-chiron" class="btn btn-teal">PRENOTA</a>
                    </div>
                </div>
            </div>

            <div class="col" data-nationality="japan" data-brand="nissan" data-engine="v6">
                <div class="card h-100">
                    <img src="/images/track-day-auto/td6.jpg" class="card-img-top card-img-fixed" alt="Nissan GTR R35 Nismo">
                    <div class="card-body">
                        <h5 class="card-title">NISSAN GTR R35 NISMO</h5>
                        <p class="card-text">Motore V6 Biturbo, 3.8 litri, 570 CV, 0-100 km/h in 2.7 secondi.</p>
                        <a href="/prenota?service=track-day&car=nissan-gtr" class="btn btn-teal">PRENOTA</a>
                    </div>
                </div>
            </div>  
        </div>
    </div>

    <%- include('../partials/footer') %>
    <%- include('../partials/scripts', { customJS: 'track-day.js' }) %>
</body>
</html>
