                    </svg>
                    Contattaci
                </a>
                <a href="/recensioni" class="hover-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-star-fill me-2 d-none d-md-inline" viewBox="0 0 16 16">
                        <path d="M3.612 15.443c-.386.197-.812-.149-.754-.575l.588-3.429-2.637-2.536c-.329-.318-.158-.888.283-.951l3.535-.514 1.578-3.194c.197-.386.735-.386.932 0l1.578 3.194 3.535.514c.441.063.612.633.283.951l-2.637 2.536.588 3.429c.058.426-.368.772-.754.575L8 13.187l-3.388 1.256z"/>
