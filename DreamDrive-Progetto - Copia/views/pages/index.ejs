    <div class="banner text-white py-4">
        <div class="container">
            <div class="row text-center">
                <div class="col-md-4">
                    <h5>Contattaci</h5>
                    <p>Email: <a href="mailto:info@dreamdrive.com" class="text-white text-decoration-none">info@dreamdrive.com</a></p>
                    <p>Tel: +39 123 456 7890</p>
                </div>
                <div class="col-md-4">
                    <h5>Dove Siamo</h5>
                    <p>Via Roma 123</p>
                    <p>20100 Milano (MI)</p>
                </div>
                <div class="col-md-4">
                    <h5>Orari</h5>
                    <p>Lun-Ven: 9:00-18:00</p>
                    <p>Sab: 9:00-12:00</p>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>
    <%- include('../partials/scripts', { customJS: 'index.js' }) %>
