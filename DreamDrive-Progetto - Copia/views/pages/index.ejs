    <div class="banner-wallpaper">
        <div class="overlay">
            <div class="button-container">
                <a href="/servizi" class="hover-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-bookmark-check-fill me-2 d-none d-md-inline" viewBox="0 0 16 16">
